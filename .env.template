# Project-root .env loaded automatically by wikitool
# Prefer this for shared project defaults; keep .wikitool/ as local runtime state.

# Bot credentials
# Get these from Special:BotPasswords on your wiki
WIKI_BOT_USER=YourUsername@BotName
WIKI_BOT_PASS=your-bot-password

# Wiki target
WIKI_URL=https://your-wiki.example.org/
WIKI_API_URL=https://your-wiki.example.org/api.php

# Rate limits in milliseconds (optional)
# WIKI_RATE_LIMIT_READ=300
# WIKI_RATE_LIMIT_WRITE=1000

# HTTP settings (optional)
# WIKI_HTTP_TIMEOUT_MS=30000
# WIKI_HTTP_RETRIES=2
