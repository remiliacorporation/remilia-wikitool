# Project-root .env, loaded automatically by wikitool.
# Copy this file to .env and fill in your values. Keep .env out of version control;
# .wikitool/ holds local runtime state and .wikitool/config.toml holds the wiki target.

# Bot credentials - required for `wikitool push` and `wikitool delete`.
# Read from the environment only; never written to config.
# Create these at Special:BotPasswords on your wiki.
WIKITOOL_BOT_USER=YourUsername@BotName
WIKITOOL_BOT_PASS=your-bot-password

# Wiki target overrides (optional).
# Normally set by `wikitool init` in .wikitool/config.toml; these env vars override that.
# Defaults target https://wiki.remilia.org.
# WIKITOOL_WIKI_URL=https://your-wiki.example.org
# WIKITOOL_WIKI_API_URL=https://your-wiki.example.org/api.php
# WIKITOOL_USER_AGENT=yourtool/1.0 (+https://your-contact.example.org)
# WIKITOOL_ARTICLE_PATH=/$1
